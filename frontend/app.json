{
  "expo": {
    "name": "Oklahoma City Car Meets",
    "slug": "oklahoma-city-car-meets",
    "version": "2.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "okccarmeets",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "runtimeVersion": "2.1.0",
    "updates": {
      "enabled": true,
      "url": "https://u.expo.dev/a936daac-9d2d-4795-aba0-e6e7554f9395",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 15000
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.velocityvisualcrew.okccarmeets",
      "buildNumber": "2",
      "usesAppleSignIn": true,
      "config": {
        "googleMapsApiKey": "AIzaSyDekipz2kW6nfOpd_c6Ku_NLwgc5N9AsUI"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Find nearby car enthusiasts and share your location for meetups",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Find nearby car enthusiasts and share your location for meetups",
        "NSCameraUsageDescription": "Take photos of your car for your garage",
        "NSPhotoLibraryUsageDescription": "Select photos for events and your garage",
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "android": {
      "package": "com.velocityvisualcrew.okccarmeets",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDekipz2kW6nfOpd_c6Ku_NLwgc5N9AsUI"
        }
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./plugins/withNoRoutingApp",
      "expo-apple-authentication",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Find nearby car enthusiasts and share your location for meetups"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#FF6B35",
          "sounds": []
        }
      ],
      "expo-secure-store",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "notification": {
      "icon": "./assets/images/icon.png",
      "color": "#FF6B35"
    }
  }
}
